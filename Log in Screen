<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>StudyTrack</title>
  <style>
    /* ─────────────────────────────────────────────────
       CSS VARIABLES
       Defining colours and sizes once here so they are
       easy to change across the whole page.

       TODO (Band 5): Expand this list to cover shadows,
       border-radius sizes, font stacks, and transition
       speeds — the Band 5 version uses ~25 variables to
       keep every visual detail consistent.
    ───────────────────────────────────────────────── */
    :root {
      --navy:       #1a3a5c;
      --navy-dark:  #122844;
      --green:      #2e7d52;
      --green-pale: #e8f5ee;
      --red:        #c0392b;
      --red-pale:   #fdecea;
      --amber:      #e8960a;
      --amber-pale: #fef8e7;
      --border:     #d4dce0;
      --bg:         #f2f4f5;
      --white:      #ffffff;
      --text:       #1e2b30;
      --text-soft:  #5c6e75;
      --radius:     5px;
    }

    /* ─── Reset ─────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Segoe UI', Tahoma, Geneva, sans-serif;
      background: var(--bg);
      color: var(--text);
      font-size: 14px;
      line-height: 1.55;
    }

    /* ─── Page visibility ────────────────────────────── */
    .page     { display: none; }
    .page.active { display: block; }

    /* ─── AUTH PAGES ─────────────────────────────────── */
    .auth-outer {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }

    .auth-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 32px 36px;
      width: 100%;
      max-width: 420px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.09);
    }

    .auth-logo {
      font-size: 22px;
      font-weight: bold;
      color: var(--navy);
      margin-bottom: 4px;
    }

    .auth-tagline {
      color: var(--text-soft);
      font-size: 13px;
      margin-bottom: 24px;
    }

    /* ─── APP SHELL ──────────────────────────────────── */

    /*
      The app shell uses position:fixed for the topbar
      and sidebar, and left-margin on the main content.

      TODO (Band 5): Replace this with a CSS Grid layout
      so the topbar and sidebar are part of the document
      flow rather than being positioned absolutely:

        .app-shell {
          display: grid;
          grid-template-columns: 220px 1fr;
          grid-template-rows: 54px 1fr;
          min-height: 100vh;
        }
        .topbar  { grid-column: 1 / -1; position: sticky; top: 0; }
        .sidebar { grid-row: 2; }
        .main    { grid-row: 2; }

      This approach is more robust and avoids z-index issues.
    */

    .topbar {
      position: fixed;
      top: 0; left: 0; right: 0;
      height: 50px;
      background: var(--navy);
      display: flex;
      align-items: center;
      padding: 0 18px;
      gap: 12px;
      z-index: 100;
    }

    .topbar-title {
      font-size: 17px;
      font-weight: bold;
      color: white;
    }

    .topbar-spacer { flex: 1; }

    .topbar-user {
      font-size: 13px;
      color: rgba(255,255,255,0.8);
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .sidebar {
      position: fixed;
      top: 50px;
      left: 0;
      bottom: 0;
      width: 200px;
      background: var(--navy-dark);
      padding: 14px 8px;
      overflow-y: auto;
      z-index: 90;
    }

    .nav-section-label {
      font-size: 10px;
      font-weight: bold;
      text-transform: uppercase;
      letter-spacing: 0.9px;
      color: rgba(255,255,255,0.3);
      padding: 0 8px;
      margin: 14px 0 6px;
    }
    .nav-section-label:first-child { margin-top: 0; }

    .nav-link {
      display: flex;
      align-items: center;
      gap: 8px;
      width: 100%;
      padding: 9px 10px;
      background: none;
      border: none;
      border-radius: var(--radius);
      color: rgba(255,255,255,0.65);
      font-size: 13px;
      font-family: inherit;
      cursor: pointer;
      text-align: left;
      transition: background 0.12s, color 0.12s;
    }
    .nav-link:hover  { background: rgba(255,255,255,0.08); color: white; }
    .nav-link.active { background: rgba(255,255,255,0.13); color: white; font-weight: bold; }

    /* TODO (Band 5): Add aria-current="page" to the active
       nav button dynamically in showSection(). This helps
       screen readers understand which page is current. */

    .main {
      margin-top: 50px;
      margin-left: 200px;
      padding: 26px 28px;
    }

    /* ─── Section header ─────────────────────────────── */
    .section-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 20px;
    }

    .section-title {
      font-size: 20px;
      font-weight: bold;
      color: var(--navy);
    }

    .section-sub {
      font-size: 13px;
      color: var(--text-soft);
      margin-top: 2px;
    }

    /* ─── Cards ──────────────────────────────────────── */
    .card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: 0 1px 6px rgba(0,0,0,0.07);
      margin-bottom: 18px;
    }

    .card-head {
      padding: 13px 18px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .card-title {
      font-weight: bold;
      color: var(--navy);
      font-size: 14px;
    }

    .card-body { padding: 18px; }

    /* ─── Stats row ──────────────────────────────────── */
    .stats-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
      margin-bottom: 18px;
    }

    /*
      TODO (Band 5): Add a fourth stat card here showing
      "Hours this week" — sessions logged in the last 7 days.
      Change the grid to: grid-template-columns: repeat(4, 1fr);
      You'll need to filter sessions by comparing their date
      to (new Date() - 7 days) using Date objects.
    */

    .stat-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-left: 4px solid var(--navy);
      border-radius: var(--radius);
      padding: 16px 18px;
      box-shadow: 0 1px 6px rgba(0,0,0,0.07);
    }

    .stat-value {
      font-size: 28px;
      font-weight: bold;
      color: var(--navy);
    }

    .stat-label {
      font-size: 12px;
      color: var(--text-soft);
      margin-top: 2px;
    }

    /* ─── Form elements ──────────────────────────────── */
    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .form-group { margin-bottom: 13px; }

    .form-label {
      display: block;
      font-size: 13px;
      font-weight: bold;
      color: var(--text);
      margin-bottom: 5px;
    }

    .req { color: var(--red); }

    .form-control {
      width: 100%;
      padding: 8px 11px;
      border: 1.5px solid var(--border);
      border-radius: var(--radius);
      font-size: 14px;
      font-family: inherit;
      color: var(--text);
      background: var(--white);
      outline: none;
      transition: border-color 0.15s;
    }

    .form-control:focus {
      border-color: var(--navy);
      box-shadow: 0 0 0 2px rgba(26,58,92,0.12);
    }

    /*
      TODO (Band 5): Add an .is-error modifier class that
      turns the border red when validation fails:
        .form-control.is-error { border-color: var(--red); }
      Then apply/remove this class in your validation logic
      instead of only showing a text error message.
    */

    textarea.form-control { resize: vertical; min-height: 72px; }

    .form-hint {
      font-size: 12px;
      color: var(--text-soft);
      margin-top: 3px;
    }

    /* Per-field error message */
    .field-err {
      font-size: 12px;
      color: var(--red);
      margin-top: 3px;
      display: none;
    }

    /* Global error/success banners */
    .msg-error {
      background: var(--red-pale);
      border: 1px solid rgba(192,57,43,0.2);
      border-radius: var(--radius);
      color: var(--red);
      padding: 9px 12px;
      font-size: 13px;
      margin-bottom: 12px;
      display: none;
    }

    .msg-success {
      background: var(--green-pale);
      border: 1px solid rgba(46,125,82,0.2);
      border-radius: var(--radius);
      color: var(--green);
      padding: 9px 12px;
      font-size: 13px;
      margin-bottom: 12px;
      display: none;
    }

    /*
      TODO (Band 5): Replace the .msg-success and .msg-error
      banners with toast notifications — small pop-up messages
      that appear in the corner of the screen and fade away
      automatically after ~3 seconds. They give feedback
      without interrupting the user's workflow.

      Basic toast structure:
        .toast-wrap { position: fixed; bottom: 20px; right: 20px; }
        .toast { background: #1a3a5c; color: white; padding: 12px 16px;
                 border-radius: 6px; margin-top: 8px; animation: fadeIn 0.2s; }
    */

    /* ─── Buttons ─────────────────────────────────────── */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 16px;
      border: 1.5px solid transparent;
      border-radius: var(--radius);
      font-size: 13px;
      font-family: inherit;
      font-weight: bold;
      cursor: pointer;
      transition: opacity 0.12s;
      line-height: 1;
    }
    .btn:hover  { opacity: 0.85; }
    .btn:active { opacity: 0.7;  }

    .btn-primary { background: var(--navy);  color: white; }
    .btn-green   { background: var(--green); color: white; }
    .btn-red     { background: var(--red);   color: white; }
    .btn-outline {
      background: transparent;
      color: var(--navy);
      border-color: var(--navy);
    }
    .btn-sm { padding: 5px 11px; font-size: 12px; }
    .btn-block { width: 100%; justify-content: center; }

    /* ─── Table ──────────────────────────────────────── */
    .table-wrap {
      overflow-x: auto;
    }

    table { width: 100%; border-collapse: collapse; font-size: 13px; }

    thead tr { background: var(--navy); }
    thead th {
      padding: 10px 13px;
      text-align: left;
      color: white;
      font-size: 12px;
      font-weight: bold;
      white-space: nowrap;
    }

    tbody tr { border-bottom: 1px solid #eee; }
    tbody tr:last-child { border-bottom: none; }
    tbody tr:hover { background: #f7f9fb; }
    tbody td { padding: 10px 13px; vertical-align: middle; }

    /* ─── Badge ──────────────────────────────────────── */
    .badge {
      display: inline-block;
      padding: 2px 9px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: bold;
      background: #dbeafe;
      color: #1e40af;
    }

    /*
      TODO (Band 5): Store a 'colour' property on each subject
      object and use it to apply a specific badge class per
      subject. This makes it easier to tell subjects apart at
      a glance. Add colour options when creating a subject:

        const COLOURS = {
          blue:   { bg: '#dbeafe', text: '#1e40af' },
          green:  { bg: '#d1fae5', text: '#065f46' },
          amber:  { bg: '#fef3c7', text: '#92400e' },
          red:    { bg: '#fee2e2', text: '#991b1b' },
        };
    */

    /* ─── Filter bar ─────────────────────────────────── */
    .filter-bar {
      display: flex;
      gap: 10px;
      margin-bottom: 14px;
      align-items: center;
    }

    .filter-bar .form-control { margin-bottom: 0; }

    /* ─── Inline edit form ───────────────────────────── */
    /*
      Band 4 uses an inline edit form that appears below the
      sessions table when the user clicks Edit on a row.

      TODO (Band 5): Replace this with a modal overlay dialog.
      A modal keeps the user on the same screen and feels more
      professional. See the Band 5 prototype for how to build
      a modal using a fixed-position backdrop + centred box.
    */
    .edit-form-wrap {
      background: var(--amber-pale);
      border: 1.5px solid var(--amber);
      border-radius: var(--radius);
      padding: 18px;
      margin-top: 16px;
      display: none;
    }

    .edit-form-wrap.visible { display: block; }

    .edit-form-title {
      font-weight: bold;
      color: var(--navy);
      margin-bottom: 14px;
      font-size: 14px;
    }

    /* ─── Info box (SQL/security notes) ─────────────── */
    .info-box {
      background: #1a2e3a;
      border-radius: var(--radius);
      padding: 12px 15px;
      font-family: 'Courier New', monospace;
      font-size: 12px;
      color: #93c5a8;
      line-height: 1.8;
      margin-bottom: 16px;
    }
    .info-box .c  { color: rgba(255,255,255,0.3); }
    .info-box .k  { color: #7ec8e3; }
    .info-box .v  { color: #f0c96e; }

    /* ─── Empty state ────────────────────────────────── */
    .empty {
      text-align: center;
      padding: 36px 20px;
      color: var(--text-soft);
    }
    .empty-icon { font-size: 34px; margin-bottom: 8px; }
    .empty-text { font-size: 14px; }

    /* ─── Password strength ──────────────────────────── */
    .pw-bars { display: flex; gap: 3px; margin-top: 5px; }
    .pw-bar  { height: 4px; flex: 1; border-radius: 2px; background: var(--border); transition: background 0.18s; }

    /* ─── Accessibility ──────────────────────────────── */
    *:focus-visible {
      outline: 2px solid var(--amber);
      outline-offset: 2px;
    }

    /*
      TODO (Band 5): Add a prefers-reduced-motion media query
      to disable transitions for users who prefer less motion:

        @media (prefers-reduced-motion: reduce) {
          *, *::before, *::after { transition-duration: 0.01ms !important; }
        }
    */
  </style>
</head>
<body>
    <div class="page active" id="page-login">
      <div class="auth-outer">
        <div class="auth-card">
          <div class="auth-logo">📚 StudyTrack</div>
          <div class="auth-tagline">Track your study sessions by subject.</div>

          <div class="msg-error" id="loginErr" role="alert"></div>

          <div class="form-group">
            <label class="form-label" for="loginEmail">
              Email address <span class="req">*</span>
            </label>
            <input class="form-control" type="email" id="loginEmail"
              placeholder="you@example.com" autocomplete="email"
              aria-required="true">
            <div class="field-err" id="loginEmailErr"></div>
          </div>

          <div class="form-group">
            <label class="form-label" for="loginPw">
              Password <span class="req">*</span>
            </label>
            <input class="form-control" type="password" id="loginPw"
              placeholder="Your password" autocomplete="current-password"
              aria-required="true">
            <div class="field-err" id="loginPwErr"></div>
          </div>

          <button class="btn btn-primary btn-block" style="margin-bottom:14px"
            onclick="doLogin()">
            Sign In
          </button>

          <p style="text-align:center;font-size:13px;color:var(--text-soft)">
            No account?
            <button class="btn btn-outline btn-sm" onclick="showPage('page-register')"
              style="margin-left:6px">Create account</button>
          </p>

          <!-- Demo credentials notice -->
          <div style="margin-top:18px;padding:10px 12px;background:var(--amber-pale);
            border:1px solid rgba(232,150,10,0.3);border-radius:var(--radius);
            font-size:12px;color:#7a5000">
            <strong>Demo login:</strong> demo@studytrack.com / Demo1234!
          </div>
        </div>
      </div>
    </div>
</body>
</html>
