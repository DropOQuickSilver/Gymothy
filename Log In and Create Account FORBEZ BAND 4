<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>StudyTrack - Auth System</title>
    <style>
        /* CSS VARIABLES & RESET */
        :root {
            --navy: #1a3a5c; --navy-dark: #122844; --red: #c0392b; --red-pale: #fdecea;
            --border: #d4dce0; --bg: #f2f4f5; --white: #ffffff; --text: #1e2b30;
            --text-soft: #5c6e75; --radius: 5px; --amber-pale: #fef8e7;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: 'Segoe UI', sans-serif; background: var(--bg); color: var(--text); font-size: 14px; }

        /* PAGE VISIBILITY */
        .page { display: none; }
        .page.active { display: block; }

        /* AUTH UI */
        .auth-outer { min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 20px; }
        .auth-card { background: var(--white); border: 1px solid var(--border); border-radius: var(--radius); padding: 32px 36px; width: 100%; max-width: 420px; box-shadow: 0 2px 12px rgba(0,0,0,0.09); }
        .auth-logo { font-size: 22px; font-weight: bold; color: var(--navy); margin-bottom: 4px; }
        .auth-tagline { color: var(--text-soft); font-size: 13px; margin-bottom: 24px; }

        /* FORM ELEMENTS */
        .form-group { margin-bottom: 13px; }
        .form-label { display: block; font-size: 13px; font-weight: bold; margin-bottom: 5px; }
        .form-control { width: 100%; padding: 8px 11px; border: 1.5px solid var(--border); border-radius: var(--radius); font-size: 14px; outline: none; }
        .form-control:focus { border-color: var(--navy); }
        .field-err { font-size: 12px; color: var(--red); margin-top: 3px; display: none; }
        .msg-error { background: var(--red-pale); border: 1px solid rgba(192,57,43,0.2); border-radius: var(--radius); color: var(--red); padding: 9px 12px; margin-bottom: 12px; display: none; }
        
        /* BUTTONS */
        .btn { display: inline-flex; align-items: center; justify-content: center; padding: 8px 16px; border: 1.5px solid transparent; border-radius: var(--radius); font-weight: bold; cursor: pointer; transition: opacity 0.12s; width: 100%; }
        .btn-primary { background: var(--navy); color: white; }
        .btn-outline { background: transparent; color: var(--navy); border-color: var(--navy); width: auto; font-size: 12px; padding: 5px 11px; }
        .btn:hover { opacity: 0.85; }

        /* APP STATE */
        .app-view { padding: 40px; text-align: center; }
    </style>
</head>
<body>

    <!-- LOGIN PAGE -->
    <div class="page active" id="page-login">
        <div class="auth-outer">
            <div class="auth-card">
                <div class="auth-logo">📚 StudyTrack</div>
                <div class="auth-tagline">Sign in to your account.</div>
                <div class="msg-error" id="loginErr"></div>
                
                <div class="form-group">
                    <label class="form-label">Email address</label>
                    <input class="form-control" type="email" id="loginEmail" placeholder="you@example.com">
                    <div class="field-err" id="loginEmailErr"></div>
                </div>
                <div class="form-group">
                    <label class="form-label">Password</label>
                    <input class="form-control" type="password" id="loginPw" placeholder="Your password">
                    <div class="field-err" id="loginPwErr"></div>
                </div>
                <button class="btn btn-primary" onclick="doLogin()">Sign In</button>
                <p style="text-align:center; margin-top:15px; color:var(--text-soft)">
                    No account? <button class="btn btn-outline" onclick="showPage('page-register')">Create account</button>
                </p>
            </div>
        </div>
    </div>

    <!-- REGISTER PAGE -->
    <div class="page" id="page-register">
        <div class="auth-outer">
            <div class="auth-card">
                <div class="auth-logo">📚 StudyTrack</div>
                <div class="auth-tagline">Create your account to get started.</div>
                <div class="msg-error" id="registerErr"></div>
                
                <div class="form-group">
                    <label class="form-label">First Name</label>
                    <input class="form-control" type="text" id="regFirst" placeholder="Jane">
                    <div class="field-err" id="regFirstErr"></div>
                </div>
                <div class="form-group">
                    <label class="form-label">Email</label>
                    <input class="form-control" type="email" id="regEmail" placeholder="jane@example.com">
                    <div class="field-err" id="regEmailErr"></div>
                </div>
                <div class="form-group">
                    <label class="form-label">Password</label>
                    <input class="form-control" type="password" id="regPw" placeholder="Min 8 characters">
                    <div class="field-err" id="regPwErr"></div>
                </div>
                <button class="btn btn-primary" onclick="doRegister()">Create Account</button>
                <p style="text-align:center; margin-top:15px; color:var(--text-soft)">
                    Already have an account? <button class="btn btn-outline" onclick="showPage('page-login')">Sign in</button>
                </p>
            </div>
        </div>
    </div>

    <!-- SIMPLE APP VIEW (POST-LOGIN) -->
    <div class="page" id="page-app">
        <div class="app-view">
            <h1>Welcome, <span id="userName">User</span>!</h1>
            <p>You are now logged into StudyTrack.</p>
            <button class="btn btn-outline" style="margin-top:20px" onclick="doLogout()">Sign Out</button>
        </div>
    </div>

    <script>
        'use strict';

        const KEYS = { users: 'st4_users', currentId: 'st4_uid' };
        let currentUser = null;

        // DATA HELPERS
        function loadJSON(key) { return JSON.parse(localStorage.getItem(key) || 'null'); }
        function saveJSON(key, val) { localStorage.setItem(key, JSON.stringify(val)); }
        function allUsers() { return loadJSON(KEYS.users) || []; }
        function genId() { return Date.now().toString(36) + Math.random().toString(36).slice(2, 5); }

        // SECURITY (Simulated Hash)
        function simulateHash(password) {
            let h = 0x811c9dc5;
            for (let i = 0; i < password.length; i++) {
                h ^= password.charCodeAt(i);
                h = Math.imul(h, 0x01000193) >>> 0;
            }
            return '$sim$' + h.toString(16);
        }

        // NAVIGATION
        function showPage(id) {
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            document.getElementById(id).classList.add('active');
        }

        function showErr(inputId, errId, msg) {
            const inp = document.getElementById(inputId);
            const err = document.getElementById(errId);
            if (inp) inp.style.borderColor = 'var(--red)';
            if (err) { err.textContent = msg; err.style.display = 'block'; }
        }

        function clearErrors() {
            document.querySelectorAll('.form-control').forEach(i => i.style.borderColor = '');
            document.querySelectorAll('.field-err, .msg-error').forEach(e => e.style.display = 'none');
        }

        // AUTH LOGIC
        function doLogin() {
            clearErrors();
            const email = document.getElementById('loginEmail').value.trim();
            const pw = document.getElementById('loginPw').value;
            const errBox = document.getElementById('loginErr');

            const user = allUsers().find(u => u.email.toLowerCase() === email.toLowerCase());
            if (!user || simulateHash(pw) !== user.passwordHash) {
                errBox.textContent = 'Incorrect email or password.';
                errBox.style.display = 'block';
                return;
            }

            loginSuccess(user);
        }

        function doRegister() {
            clearErrors();
            const first = document.getElementById('regFirst').value.trim();
            const email = document.getElementById('regEmail').value.trim();
            const pw = document.getElementById('regPw').value;

            if (first === "" || email === "" || pw.length < 8) {
                alert("Please fill all fields. Password must be 8+ chars.");
                return;
            }

            if (allUsers().find(u => u.email.toLowerCase() === email.toLowerCase())) {
                showErr('regEmail', 'regEmailErr', 'Email already exists.');
                return;
            }

            const newUser = { id: genId(), first, email, passwordHash: simulateHash(pw) };
            const users = allUsers();
            users.push(newUser);
            saveJSON(KEYS.users, users);
            loginSuccess(newUser);
        }

        function loginSuccess(user) {
            currentUser = user;
            localStorage.setItem(KEYS.currentId, user.id);
            document.getElementById('userName').textContent = user.first;
            showPage('page-app');
        }

        function doLogout() {
            localStorage.removeItem(KEYS.currentId);
            showPage('page-login');
        }

        // AUTO-LOGIN CHECK
        window.onload = () => {
            const savedId = localStorage.getItem(KEYS.currentId);
            if (savedId) {
                const user = allUsers().find(u => u.id === savedId);
                if (user) loginSuccess(user);
            }
        };
    </script>
</body>
</html>
